{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test"],
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**",
        "**/playwright/**",
        "**/@playwright/**"
      ],
      "smartStep": true
    }
  ]
}